# ======================================================================
# DSE Stock Monitor — environment configuration
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env to version control.
# ======================================================================

# ---- Twilio WhatsApp (messages only — no voice/calls) ----------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio sandbox number (or your approved WhatsApp sender)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Your phone, joined to the Twilio WhatsApp sandbox
RECIPIENT_WHATSAPP_NUMBER=whatsapp:+8801XXXXXXXXX

# ---- Target condition -------------------------------------------------
TARGET_MIN_PRICE=143
TARGET_MAX_PRICE=145

# ---- Monitoring -------------------------------------------------------
# DSE trades Sun-Thu: continuous 10:00 AM - 2:20 PM, post-closing
# session 2:20 - 2:30 PM. Monitoring runs through post-close.
POLLING_INTERVAL_SECONDS=120
TRADING_START=10:00
TRADING_CONTINUOUS_END=14:20
TRADING_END=14:30
TIMEZONE=Asia/Dhaka

# ---- AI analysis ------------------------------------------------------
AI_ENABLED=true
AI_SPIKE_THRESHOLD_PCT=2.0
AI_HISTORY_SIZE=20

# ---- Alerts -----------------------------------------------------------
# false = do not re-send an alert for the same unchanged price
REALERT_ON_SAME_PRICE=false
ALERT_COOLDOWN_SECONDS=600
