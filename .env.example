# ======================================================================
# DSE Terminal — environment configuration
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real .env to version control.
#
# Everything here is optional: Twilio credentials, the refresh interval,
# stock selections, watchlists and alert rules can all be set INSIDE the
# app. This file just lets you pre-seed them.
# ======================================================================

# ---- Twilio WhatsApp (messages only — no voice/calls) ----------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio sandbox number (or your approved WhatsApp sender)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Your phone, joined to the Twilio WhatsApp sandbox
RECIPIENT_WHATSAPP_NUMBER=whatsapp:+8801XXXXXXXXX

# ---- Market platform (V2) --------------------------------------------
# How often the WHOLE market is re-scraped while open (seconds, min 30).
REFRESH_INTERVAL_SECONDS=60
# Auto-prune stored price history older than this many days.
HISTORY_RETENTION_DAYS=30

# ---- Monitoring -------------------------------------------------------
# DSE trades Sun-Thu: continuous 10:00 AM - 2:20 PM, post-closing
# session 2:20 - 2:30 PM. Monitoring runs through post-close.
TRADING_START=10:00
TRADING_CONTINUOUS_END=14:20
TRADING_END=14:30
TIMEZONE=Asia/Dhaka

# ---- Legacy single-stock target (unused by V2) -----------------------
TARGET_MIN_PRICE=143
TARGET_MAX_PRICE=145
POLLING_INTERVAL_SECONDS=120

# ---- AI analysis ------------------------------------------------------
AI_ENABLED=true
AI_SPIKE_THRESHOLD_PCT=2.0
AI_HISTORY_SIZE=20

# ---- Alerts -----------------------------------------------------------
# false = do not re-send an alert for the same unchanged price
REALERT_ON_SAME_PRICE=false
ALERT_COOLDOWN_SECONDS=600
